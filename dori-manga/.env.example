# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Drive（PDFが格納されているフォルダのID）
# フォルダURLの末尾: https://drive.google.com/drive/folders/XXXXXXXX
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Google Sheets（管理スプレッドシートのID）
# シートURLの末尾: https://docs.google.com/spreadsheets/d/XXXXXXXX/
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# Google OAuth2認証情報（QQQプロジェクトと共通）
# Google Cloud Console → 認証情報 → QQQ-Trading-Desktop-Client → JSONダウンロード
# プロジェクトID: qqq-trading-system-496304
GOOGLE_CREDENTIALS_PATH=credentials.json

# 認証トークン（初回実行後に自動生成される。Gitに含めないこと）
GOOGLE_TOKEN_PATH=token.json

# シート名（変更する場合）
SHEET_NAME=どり漫画管理
